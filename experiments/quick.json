{
  "name": "quick",
  "seed": 0,
  "model": {
    "name": "simple_conv",
    "params": {"channels": 48, "n_blocks": 3, "kernel_size": 3}
  },
  "encoder": {"name": "default", "max_n": 14, "max_turns": 10},
  "data": {
    "sources": [
      {"kind": "supervised", "weight": 0.7, "set": "train_small"},
      {
        "kind": "selfplay",
        "weight": 0.3,
        "specs": [
          [6, [2, 3]], [9, [3, 4]], [10, [4, 4]],
          [7, [2, 2, 2]], [9, [3, 3, 3]], [10, [3, 3, 3]],
          [8, [2, 2, 2, 2]], [7, [1, 1, 1, 1, 1, 1, 1]]
        ],
        "games_per_iter": 6,
        "n_simulations": 24,
        "c_puct": 1.5,
        "dirichlet_alpha": 0.3,
        "dirichlet_eps": 0.25,
        "temperature_moves": 4,
        "capacity": 10000
      }
    ]
  },
  "loop": {
    "iters": 15,
    "steps_per_iter": 100,
    "batch_size": 256,
    "lr": 1e-3,
    "weight_decay": 1e-4,
    "eval_every": 3,
    "eval_n_simulations": 48
  },
  "wandb": {
    "project": "main_street",
    "mode": "online"
  }
}
